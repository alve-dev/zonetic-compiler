-|
 | Write a program to check whether a given number is prime or not.
 | Once done, print all prime numbers between 1 and 100.
 |-

mut counter = 2
while counter <= 100 {
    inmut erastostenes = (
        (counter == 2) or (counter == 3) or
        (counter == 5) or (counter == 7) or
        (counter % 2 != 0) and (counter % 3 != 0) and
        (counter % 5 != 0) and (counter % 7 != 0)
    )

    if erastostenes {
        print(counter)
    }
    counter += 1
}